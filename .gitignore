# Xcode project — regenerated by XcodeGen from project.yml
*.xcodeproj/

# Xcode build artifacts
DerivedData/
build/
*.xcworkspace/xcuserdata/

# Swift Package Manager
.build/
.swiftpm/
Package.resolved

# macOS
.DS_Store
*.dSYM
*.dSYM.zip

# Code signing
*.mobileprovision
*.p12

# Provisioning profiles
*.provisionprofile

# Playground
timeline.xctimeline
playground.xcworkspace

# Python virtualenvs (uv creates .venv in project root)
.venv/
uv.lock

# Scratch space (commit messages, temp files)
.tmp/

# Beads task tracker (local Dolt DB — not git-tracked)
.beads/

# AI agent config
!.claude/
.claude/*
!.claude/settings.json
!.claude/skills/
!.claude/skills/**
!.claude/agents/
!.claude/agents/**

# IDE
*.xccheckout
*.moved-aside
*.hmap
*.ipa
*.xcuserstate
xcuserdata/
IDEWorkspaceChecks.plist
